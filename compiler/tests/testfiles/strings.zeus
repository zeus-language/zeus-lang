
use std::io;
use core::libc as libc;
use std::str;

fn main() : i32 {
    let mut hello : std::str::string = string::from_c_str(r"Hello, World!" as *u8);
    defer hello.destroy();
    println("String: ${hello}");
    printf(r"length: %d\n" as *u8, hello.length());
    printf(r"capacity: %d\n" as *u8, hello.capacity());

    return 0;
}