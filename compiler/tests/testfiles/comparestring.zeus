use std::str;

fn main() : i32 {
    let mut a : string = string::from_slice("Hello, World!");
    let mut b : string = string::from_slice("Hello, World!");
    let mut c : string = string::from_slice("Hello, Zeus!");
    let mut d : string = string::from_slice("Hello, world!");
    defer {
        a.destroy();
        b.destroy();
        c.destroy();
        d.destroy();
    }
    // Compare strings
    if a == b {
        println("a and b are equal.");
    } else {
        println("a and b are not equal.");
    }

    if a == c {
        println("a and c are equal.");
    } else {
        println("a and c are not equal.");
    }

    if a == d {
        println("a and d are equal.");
    } else {
        println("a and d are not equal.");
    }

    return 0;
}