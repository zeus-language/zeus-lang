
type DWORD = u32;
type LPCSTR = *u8;
type LPCTSTR = *u8;
type UINT = u32;
type FILE = void;
type BOOL = bool;


extern pub fn PathFileExistsA(pszPath :LPCSTR) : BOOL;

extern fn  GetFileAttributesA(
            lpFileName : LPCSTR
          ) : DWORD;

fn directory_exists(szPath : LPCTSTR) : bool
{
  let dwAttrib : DWORD = GetFileAttributes(szPath);

  return (dwAttrib != INVALID_FILE_ATTRIBUTES &&
         (dwAttrib & FILE_ATTRIBUTE_DIRECTORY));
}
